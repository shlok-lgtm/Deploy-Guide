# Basis Protocol — Environment Variables
# ========================================
# On Replit: set these in the Secrets tab (lock icon)
# Locally: copy to .env and fill in values

# Database (REQUIRED)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CoinGecko Pro (REQUIRED for data collection)
COINGECKO_API_KEY=CG-your-key-here

# Etherscan (REQUIRED for holder data)
ETHERSCAN_API_KEY=your-etherscan-key

# Optional
ALCHEMY_API_KEY=

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# Worker
WORKER_ENABLED=true
COLLECTION_INTERVAL=60

# Content Engine (optional — for draft generation and governance intel)
GOVERNANCE_DB_URL=postgresql://user:password@host:5432/governance_intel
ANTHROPIC_API_KEY=sk-ant-your-key
SII_API_BASE=http://localhost:8000
