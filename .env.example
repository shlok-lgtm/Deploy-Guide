# Basis Protocol — Environment Variables
# ========================================
# Production: set these as Railway service variables in the
# valiant-celebration project.
# Local dev: copy to .env (gitignored) and fill in values.
#
# DATABASE_URL is the single source of truth for Postgres connection
# details. Do not also set PGHOST/PGPORT/PGUSER/PGPASSWORD/PGDATABASE —
# they are derived from DATABASE_URL where needed (see app/discovery.py
# for dbt).
#
# IMPORTANT: do NOT append `?options=-c%20statement_timeout=...` or any
# other libpq `options=` parameter to DATABASE_URL. The Neon pooler
# (pgbouncer in transaction mode) rejects startup options and the whole
# pool fails to come up. This is exactly what broke production on
# 2026-05-10. Set per-query timeouts with `SET LOCAL statement_timeout`
# inside a transaction instead.

# Database (REQUIRED) — Neon pooler endpoint (keep -pooler suffix)
DATABASE_URL=postgresql://<user>:<password>@ep-<id>-pooler.<region>.aws.neon.tech/<dbname>?sslmode=require

# CoinGecko Pro (REQUIRED for data collection)
COINGECKO_API_KEY=CG-your-key-here

# Etherscan (REQUIRED for holder data)
ETHERSCAN_API_KEY=your-etherscan-key

# Optional
ALCHEMY_API_KEY=
HELIUS_API_KEY=

# Server
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
ADMIN_KEY=

# Worker
WORKER_ENABLED=true
COLLECTION_INTERVAL=60

# Keeper (oracle publisher — TypeScript service)
KEEPER_ENABLED=false
KEEPER_PRIVATE_KEY=

# Content Engine (optional — for draft generation and governance intel)
GOVERNANCE_DB_URL=
ANTHROPIC_API_KEY=sk-ant-your-key
SII_API_BASE=http://localhost:8000
