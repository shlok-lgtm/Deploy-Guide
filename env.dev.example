# basis-hub local development environment template
# Generated by Phase A2 — see docs/development/env-var-inventory.md for full reference
#
# Usage: cp env.dev.example env.dev && $EDITOR env.dev
# DO NOT COMMIT env.dev — it is gitignored.

# === SECRET (operator must fill) ===
# These variables contain sensitive material. The inventory marks each as
# "Skip" for dev unless the corresponding subsystem is actively being tested.
# Operator: replace REPLACE_ME_* placeholders with real keys only when needed;
# leave commented-out lines as-is otherwise.

# Admin endpoint authentication
# Category: SECRET
# Required: N
ADMIN_KEY=dev-admin-key-unsafe

# Ethereum RPC provider primary key
# Category: SECRET
# Required: N
# Inventory dev default: Skip or `operator-provided` — public RPC endpoints for local chains only
#ALCHEMY_API_KEY=REPLACE_ME_ALCHEMY_KEY

# Claude API access for analysis/drafting
# Category: SECRET
# Required: N
# Inventory dev default: Skip (cost tracker blocks calls gracefully). Set only when testing engine approval flow.
#ANTHROPIC_API_KEY=REPLACE_ME_ANTHROPIC_KEY

# GitHub personal access token for engine commits
# Category: SECRET
# Required: N
# Inventory dev default: Skip or create test PAT for PR testing
#BASIS_ENGINE_GITHUB_PAT=REPLACE_ME_GITHUB_PAT

# Blockscout block explorer API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — use public endpoints or local explorer
#BLOCKSCOUT_API_KEY=REPLACE_ME_BLOCKSCOUT_KEY

# Coinbase Developer Platform API key ID (x402 payments, part 1/2)
# Category: SECRET
# Required: N
# Inventory dev default: Skip unless testing x402 payments
#CDP_API_KEY_ID=REPLACE_ME_CDP_KEY_ID

# Coinbase Developer Platform API secret (x402 payments, part 2/2; base64-encoded 64-byte seed+pub)
# Category: SECRET
# Required: N
# Inventory dev default: Skip unless testing x402 payments
#CDP_API_KEY_SECRET=REPLACE_ME_CDP_KEY_SECRET

# CoinGecko API key for price/market data
# Category: SECRET
# Required: N
# Inventory dev default: Skip (free tier needs no auth)
#COINGECKO_API_KEY=REPLACE_ME_COINGECKO_KEY

# Dwellir RPC provider API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — use Alchemy or free RPC
#DWELLIR_API_KEY=REPLACE_ME_DWELLIR_KEY

# Full Dwellir Ethereum RPC URL (overrides API key)
# Category: SECRET
# Required: N
# Inventory dev default: Skip
#DWELLIR_ETH_URL=REPLACE_ME_DWELLIR_ETH_URL

# Full Dwellir Base RPC URL (overrides API key)
# Category: SECRET
# Required: N
# Inventory dev default: Skip
#DWELLIR_BASE_URL=REPLACE_ME_DWELLIR_BASE_URL

# Etherscan API key for contract/tx data
# Category: SECRET
# Required: N
# Inventory dev default: Skip or `operator-provided` — limited free tier; use only if testing heavy contract work
#ETHERSCAN_API_KEY=REPLACE_ME_ETHERSCAN_KEY

# Firecrawl web scraping API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for core functionality
#FIRECRAWL_API_KEY=REPLACE_ME_FIRECRAWL_KEY

# Helius Solana RPC provider API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip unless testing Solana collectors
#HELIUS_API_KEY=REPLACE_ME_HELIUS_KEY

# Keeper service private key (enables keeper)
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required if keeper disabled
#KEEPER_PRIVATE_KEY=REPLACE_ME_KEEPER_PRIVATE_KEY

# Parallel RPC/data provider API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for dev
#PARALLEL_API_KEY=REPLACE_ME_PARALLEL_KEY

# Reducto OCR API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for core functionality
#REDUCTO_API_KEY=REPLACE_ME_REDUCTO_KEY

# Resend email delivery service API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — falls back safely; no email in dev
#RESEND_API_KEY=REPLACE_ME_RESEND_KEY

# Slack webhook for engine artifact notifications
# Category: SECRET
# Required: N
# Inventory dev default: Skip — falls back to stdout
#SLACK_ENGINE_WEBHOOK_URL=REPLACE_ME_SLACK_WEBHOOK_URL

# Tally governance API key
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for dev
#TALLY_API_KEY=REPLACE_ME_TALLY_KEY

# Telegram bot token for alerting
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for dev
#TELEGRAM_BOT_TOKEN=REPLACE_ME_TELEGRAM_BOT_TOKEN

# Telegram chat ID for alerts
# Category: SECRET
# Required: N
# Inventory dev default: Skip — not required for dev
#TELEGRAM_CHAT_ID=REPLACE_ME_TELEGRAM_CHAT_ID

# === INFRASTRUCTURE (defaults provided) ===

# PostgreSQL connection string
# Category: INFRASTRUCTURE
# Required: N (functionally required for production; required for any DB-backed dev work)
# Inventory dev default: Neon dev branch or local PostgreSQL (e.g. postgresql://user:pass@localhost:5432/basis_dev)
DATABASE_URL=REPLACE_ME_NEON_DEV_BRANCH_URL

# HTTP server listening port (same as API_PORT)
# Category: INFRASTRUCTURE
# Required: N
PORT=5000

# HTTP server bind address
# Category: INFRASTRUCTURE
# Required: N
# Inventory: no dev-specific override; using production default (safe for local)
API_HOST=0.0.0.0

# HTTP server port (alias for PORT)
# Category: INFRASTRUCTURE
# Required: N
API_PORT=5000

# x402 payment protocol facilitator endpoint
# Category: INFRASTRUCTURE
# Required: N
X402_FACILITATOR_URL=https://x402.org/facilitator

# === FEATURE_FLAG (defaults provided — set permissively for dev) ===

# Bypass git operations in engine approval flow (returns fake URLs instead of pushing)
# Category: FEATURE_FLAG
# Required: N
BASIS_ENGINE_TEST_MODE=true

# Enable value-based backlog filtering
# Category: FEATURE_FLAG
# Required: N
# Inventory: no explicit dev override; keeping production default (off)
BACKLOG_VALUE_FILTER=false

# Enable Etherscan ↔ Blockscout comparison
# Category: FEATURE_FLAG
# Required: N
BLOCKSCOUT_COMPARISON_ENABLED=false

# Enable on-chain keeper service
# Category: FEATURE_FLAG
# Required: N
KEEPER_ENABLED=false

# Enable mempool transaction monitoring
# Category: FEATURE_FLAG
# Required: N
MEMPOOL_WATCHER_ENABLED=false

# Enable Morpho Blue protocol collection
# Category: FEATURE_FLAG
# Required: N
MORPHO_BLUE_COLLECTOR_ENABLED=false

# Comma-separated collector names to disable during scoring cycles
# Category: FEATURE_FLAG
# Required: N
SCORING_COLLECTORS_DISABLED=web_research,solana_program_monitor

# === TUNING (defaults provided — faster intervals OK for dev) ===

# Collateral floor (USD) to promote protocol to backlog
# Category: TUNING
# Required: N
BACKLOG_COLLATERAL_THRESHOLD=100000

# Value floor (USD) for backlog → index promotion
# Category: TUNING
# Required: N
BACKLOG_PROMOTE_THRESHOLD=500000

# Max Claude API calls per UTC day
# Category: TUNING
# Required: N
BASIS_ENGINE_LLM_DAILY_CALL_CEILING=10

# Max monthly USD spend on Claude API
# Category: TUNING
# Required: N
BASIS_ENGINE_LLM_MONTHLY_BUDGET_USD=50.0

# Max concurrent Blockscout API requests
# Category: TUNING
# Required: N
BLOCKSCOUT_CONCURRENCY=2

# Hours between CDA extraction cycles
# Category: TUNING
# Required: N
CDA_COLLECTION_INTERVAL_HOURS=6

# TVL threshold ($USD) for chain inclusion
# Category: TUNING
# Required: N
CHAIN_EXPANSION_TVL_THRESHOLD=1000000

# Minutes between data collection cycles
# Category: TUNING
# Required: N
COLLECTION_INTERVAL=10

# Max holders to index per coin on startup
# Category: TUNING
# Required: N
INDEXER_HOLDERS_PER_COIN=100

# Coverage % threshold for protocol promotion
# Category: TUNING
# Required: N
PROTOCOL_PROMOTE_COVERAGE_PCT=10

# Minutes between scoring cycles
# Category: TUNING
# Required: N
SCORING_INTERVAL=15

# Number of uvicorn worker processes (1 avoids scheduler duplication issue in dev)
# Category: TUNING
# Required: N
WEB_WORKERS=1

# === METADATA ===

# Alert recipient email address
# Category: METADATA
# Required: N
# Inventory: no dev-specific override; production default retained
ALERT_EMAIL=shlok@basisprotocol.xyz

# Arbitrum oracle contract address
# Category: METADATA
# Required: N
# Inventory dev default: Skip — oracle capability check will report false
#ARBITRUM_ORACLE_ADDRESS=

# State attestation public key verification
# Category: METADATA
# Required: N
# Inventory dev default: Skip
#ATTESTOR_PUBLIC_KEY=

# Base chain oracle contract address
# Category: METADATA
# Required: N
# Inventory dev default: Skip
#BASE_ORACLE_ADDRESS=

# Base chain SBT contract address
# Category: METADATA
# Required: N
# Inventory dev default: Skip unless testing SBT mint flow
#BASE_SBT_ADDRESS=

# USDC payment receiver wallet (Base)
# Category: METADATA
# Required: N
# Inventory dev default: Skip
#BASIS_PAYMENT_WALLET=

# Local API base URL for scripts
# Category: METADATA
# Required: N
# Inventory: no dev-specific value; uncomment + point at local server if running backfill scripts
#BASIS_API_BASE=http://localhost:5000

# Public API URL for client scripts
# Category: METADATA
# Required: N
# Inventory: no dev-specific override; production default retained
BASIS_API_URL=https://basisprotocol.xyz

# Primary block explorer (`blockscout` or `etherscan`)
# Category: METADATA
# Required: N
# Inventory: no dev-specific override; production default retained
BLOCK_EXPLORER_PROVIDER=blockscout

# Public-facing domain for page rendering
# Category: METADATA
# Required: N
CANONICAL_BASE_URL=http://localhost:5000

# CORS allowed origins (comma-separated)
# Category: METADATA
# Required: N
CORS_ORIGINS=*

# Public base URL for health checks
# Category: METADATA
# Required: N
PUBLIC_URL=http://localhost:5000

# SII service base URL
# Category: METADATA
# Required: N
SII_API_BASE=http://localhost:5000

# x402 network chain (eip155:8453 = Base mainnet, eip155:84532 = Base Sepolia)
# Category: METADATA
# Required: N
X402_NETWORK=eip155:84532
